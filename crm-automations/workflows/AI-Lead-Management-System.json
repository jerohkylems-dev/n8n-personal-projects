        "body": "{\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a real estate lead qualification assistant.\\n\\nYour task is to decide if a lead is HOT or NORMAL.\\n\\nRules:\\nHOT = serious buyer, has budget, clear intent, wants to buy soon\\nNORMAL = just browsing, unsure, or long timeline\\n\\nLead data:\\nBudget: {{$json.budgetRange}}\\nInterest: {{$json.interestType}}\\nTimeline: {{$json.decisionTimeline}}\\n\\nIMPORTANT:\\nReturn ONLY one word:\\nHOT or NORMAL\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
